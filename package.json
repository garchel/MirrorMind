{
  "name": "mirrormind",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "tauri dev",
    "build": "tsc -b && vite build",
    "build:desktop": "tauri build --debug",
    "build:desktop:bundle": "tauri build --bundles nsis",
    "build:e2e:windows": "tauri build --debug --no-bundle --features e2e --config src-tauri/tauri.e2e.conf.json",
    "lint": "oxlint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e:windows": "node tests/e2e/run-windows-e2e.mjs",
    "test:ci:frontend": "vitest run --retry=0 --reporter=default --reporter=junit --outputFile.junit=test-results/frontend.junit.xml",
    "test:ci:rust": "cargo test --manifest-path src-tauri/Cargo.toml --no-fail-fast -- --nocapture",
    "test:coverage:frontend": "vitest run --coverage",
    "test:coverage:rust": "cargo llvm-cov --manifest-path src-tauri/Cargo.toml --workspace --all-features",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@lezer/highlight": "^1.2.3",
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-dialog": "^2.4.3",
    "entities": "^8.0.0",
    "lucide-react": "^1.24.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@wdio/cli": "^9.29.1",
    "@wdio/globals": "^9.29.1",
    "@wdio/junit-reporter": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "@wdio/tauri-plugin": "^1.2.0",
    "@wdio/tauri-service": "^1.2.0",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "@wdio/native-utils": "2.5.0"
  }
}
